# Get your API token from: https://track.toggl.com/profile
TOGGL_API_TOKEN=your_api_token_here

# [LEGACY] Password for the local Streamlit dashboard (default: 290391)
DASHBOARD_PASSWORD=290391

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Frontend (Vite) Configuration
# Leave unset to run the web app in demo mode with mock data.
# Set both values to enable real Supabase auth and data reads in the hosted frontend.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
